{
  "manifest_version": 3,
  "name": "SUTD Location Chatbot",
  "version": "1.0",
  "description": "Query a location that you would like to know the code for",
  "permissions": ["storage", "offscreen"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Open Chatbot"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "model.onnx",
        "model.onnx.data",
        "tokenizer.json",
        "ort.min.js",
        "*.wasm",
        "offscreen.html",
        "offscreen.js",
        "rooms.json"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}